{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adl-spec.org/profiles/governance/1.0/schema.json",
  "title": "ADL Governance Profile",
  "description": "JSON Schema for ADL documents declaring the governance profile (urn:adl:profile:governance:1.0). Extends the base ADL schema via allOf composition.",
  "$defs": {
    "extensions": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false,
      "description": "Vendor-namespaced extensions. Keys are reverse-domain identifiers."
    }
  },
  "allOf": [
    { "$ref": "https://adl-spec.org/0.1/schema.json" }
  ],
  "type": "object",
  "required": ["compliance_framework", "autonomy"],
  "properties": {
    "profiles": {
      "type": "array",
      "contains": { "const": "urn:adl:profile:governance:1.0" }
    },
    "compliance_framework": {
      "type": "object",
      "required": ["primary_framework"],
      "properties": {
        "primary_framework": {
          "type": "string",
          "enum": [
            "NIST_800_53",
            "SOC2_TYPE_II",
            "ISO_27001",
            "ISO_42001",
            "GDPR",
            "HIPAA",
            "PCI_DSS",
            "EU_AI_ACT",
            "IMDA_AGENTIC",
            "NIST_AI_RMF"
          ]
        },
        "control_mappings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["framework", "control_id", "status"],
            "properties": {
              "framework": { "type": "string" },
              "control_id": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["implemented", "partial", "planned", "not_applicable"]
              },
              "extensions": { "$ref": "#/$defs/extensions" }
            },
            "additionalProperties": false
          }
        },
        "audit_dates": {
          "type": "object",
          "properties": {
            "last_audit": { "type": "string", "format": "date-time" },
            "next_audit": { "type": "string", "format": "date-time" },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "autonomy": {
      "type": "object",
      "required": ["tier", "basis", "classified_by", "classified_at"],
      "properties": {
        "tier": {
          "type": "integer",
          "enum": [1, 2, 3]
        },
        "basis": {
          "type": "string",
          "minLength": 1
        },
        "classified_by": {
          "type": "string",
          "minLength": 1
        },
        "classified_at": {
          "type": "string",
          "format": "date-time"
        },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "risk_classification": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "autonomy_level": {
          "type": "string",
          "enum": ["L0", "L1", "L2", "L3", "L4", "L5"]
        },
        "assessed_by": { "type": "string" },
        "assessed_at": { "type": "string", "format": "date-time" },
        "rationale": { "type": "string" },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "human_oversight": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["none", "on_exception", "periodic", "continuous"]
        },
        "role": { "type": "string" },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "response_time_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "intervention_model": {
          "type": "string",
          "enum": ["approve_reject", "plan_editing", "monitor_only"]
        },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "incident_response": {
      "type": "object",
      "required": ["policy_documented"],
      "properties": {
        "policy_documented": { "type": "boolean" },
        "last_tested": { "type": "string", "format": "date-time" },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "evaluation_attestation": {
      "type": "object",
      "required": ["result", "evaluator", "evaluation_date"],
      "properties": {
        "result": {
          "type": "string",
          "enum": ["passed", "conditional", "failed"]
        },
        "evaluator": { "type": "string", "minLength": 1 },
        "evaluation_date": { "type": "string", "format": "date-time" },
        "methodology": {
          "type": "string",
          "enum": ["automated_benchmark", "red_team", "third_party_audit", "sandbox", "internal_review"]
        },
        "expires_at": { "type": "string", "format": "date-time" },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "disclosure": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": { "type": "boolean" },
        "known_limitations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "prohibited_uses": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "user_responsibilities": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "reporting_contact": {
          "type": "string",
          "format": "uri"
        },
        "disclosure_version": { "type": "string" },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "safety_reviews": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "frequency": { "type": "string" },
        "last_review": { "type": "string", "format": "date-time" },
        "next_review": { "type": "string", "format": "date-time" },
        "review_board": { "type": "string" },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "properties": {
        "ownership": {
          "type": "object",
          "properties": {
            "owner": { "type": "string" },
            "delegate": { "type": "string" },
            "contact": { "type": "string", "format": "email" },
            "user_escalation_contact": { "type": "string", "format": "uri" },
            "decision_boundaries": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["decision_type", "owner"],
                "properties": {
                  "decision_type": { "type": "string" },
                  "owner": {
                    "type": "string",
                    "enum": ["human_only", "agent", "human_in_loop"]
                  },
                  "rationale": { "type": "string" },
                  "extensions": { "$ref": "#/$defs/extensions" }
                },
                "additionalProperties": false
              }
            },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "approval_workflow": {
          "type": "object",
          "properties": {
            "required": { "type": "boolean" },
            "approvers": {
              "type": "array",
              "items": { "type": "string" }
            },
            "approval_type": {
              "type": "string",
              "enum": ["any", "all", "quorum"]
            },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "audit_trail": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "retention_days": { "type": "integer", "minimum": 0 },
            "destination": { "type": "string", "format": "uri" },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "lifecycle_governance": {
          "type": "object",
          "properties": {
            "transition_policy": {
              "type": "object",
              "properties": {
                "requires_approval": { "type": "boolean" },
                "approvers": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "approval_type": {
                  "type": "string",
                  "enum": ["any", "all", "quorum"]
                },
                "notice_period_days": { "type": "integer", "minimum": 0 },
                "allowed_transitions": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "extensions": { "$ref": "#/$defs/extensions" }
              },
              "additionalProperties": false
            },
            "last_transition": {
              "type": "object",
              "properties": {
                "from_status": {
                  "type": "string",
                  "enum": ["draft", "active", "deprecated", "retired"]
                },
                "to_status": {
                  "type": "string",
                  "enum": ["draft", "active", "deprecated", "retired"]
                },
                "approved_by": { "type": "string" },
                "approved_at": { "type": "string", "format": "date-time" },
                "reason": { "type": "string" },
                "extensions": { "$ref": "#/$defs/extensions" }
              },
              "additionalProperties": false
            },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "governance_record_ref": {
      "type": "string",
      "format": "uri"
    }
  },
  "if": {
    "properties": {
      "autonomy": {
        "properties": {
          "tier": { "enum": [2, 3] }
        },
        "required": ["tier"]
      }
    },
    "required": ["autonomy"]
  },
  "then": {
    "required": ["human_oversight", "incident_response", "disclosure"],
    "properties": {
      "human_oversight": {
        "required": ["triggers", "response_time_minutes"]
      },
      "incident_response": {
        "properties": {
          "policy_documented": { "const": true }
        }
      },
      "disclosure": {
        "properties": {
          "required": { "const": true }
        }
      }
    },
    "if": {
      "properties": {
        "autonomy": {
          "properties": {
            "tier": { "const": 3 }
          }
        }
      }
    },
    "then": {
      "required": ["human_oversight", "incident_response", "disclosure", "evaluation_attestation"],
      "properties": {
        "evaluation_attestation": {
          "properties": {
            "result": { "const": "passed" }
          }
        }
      }
    }
  },
  "unevaluatedProperties": false
}
