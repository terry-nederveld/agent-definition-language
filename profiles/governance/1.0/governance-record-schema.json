{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adl-spec.org/profiles/governance/1.0/governance-record-schema.json",
  "title": "ADL Governance Record",
  "description": "Schema for governance records that accompany ADL documents declaring the governance profile. See the Governance Record Specification for normative requirements.",
  "type": "object",
  "required": ["agent_ref", "record_version", "updated_at"],
  "properties": {
    "agent_ref": {
      "type": "string",
      "format": "uri",
      "description": "URI to the ADL document this record accompanies"
    },
    "record_version": {
      "type": "string",
      "description": "Version of this governance record"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "incident_escalation": {
      "type": "object",
      "required": ["contacts", "triggers"],
      "properties": {
        "contacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["role", "contact", "response_time_minutes"],
            "properties": {
              "role": {
                "type": "string",
                "description": "Role in the escalation chain"
              },
              "contact": {
                "type": "string",
                "format": "uri",
                "description": "URI for the contact"
              },
              "response_time_minutes": {
                "type": "integer",
                "minimum": 1,
                "description": "Maximum response time SLA in minutes"
              },
              "severity_threshold": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"],
                "description": "Minimum severity that routes to this contact"
              }
            },
            "additionalProperties": false
          }
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "Conditions that activate the escalation process"
        },
        "external_reporting_required": {
          "type": "boolean",
          "description": "Whether incidents must be reported to external authorities"
        },
        "reporting_framework": {
          "type": "string",
          "description": "External reporting framework identifier"
        },
        "external_reporting_contact": {
          "type": "string",
          "format": "uri",
          "description": "URI for external reporting"
        },
        "last_tested": {
          "type": "string",
          "format": "date-time",
          "description": "When the escalation path was last verified"
        }
      },
      "if": {
        "properties": {
          "external_reporting_required": { "const": true }
        },
        "required": ["external_reporting_required"]
      },
      "then": {
        "required": ["contacts", "triggers", "external_reporting_contact"]
      },
      "additionalProperties": false
    },
    "oversight_operations": {
      "type": "object",
      "properties": {
        "escalation_contact": {
          "type": "string",
          "format": "uri",
          "description": "URI of the person, team, or notification endpoint for oversight alerts"
        },
        "audit_cadence": {
          "type": "string",
          "description": "Review frequency for oversight effectiveness"
        },
        "review_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "reviewer"],
            "properties": {
              "date": {
                "type": "string",
                "format": "date-time"
              },
              "reviewer": {
                "type": "string"
              },
              "findings_summary": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "evaluation_detail": {
      "type": "object",
      "properties": {
        "dimensions_covered": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "task_execution_accuracy",
              "policy_compliance",
              "tool_calling_correctness",
              "robustness",
              "security",
              "multi_agent_behavior"
            ]
          }
        },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "Conditions attached to a conditional evaluation result"
        },
        "report_uri": {
          "type": "string",
          "format": "uri",
          "description": "URI to the full evaluation report"
        },
        "continuous_testing_enabled": {
          "type": "boolean",
          "description": "Whether continuous post-deployment testing is active"
        },
        "evaluation_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "evaluator", "result"],
            "properties": {
              "date": {
                "type": "string",
                "format": "date-time"
              },
              "evaluator": {
                "type": "string"
              },
              "result": {
                "type": "string",
                "enum": ["passed", "conditional", "failed"]
              },
              "report_uri": {
                "type": "string",
                "format": "uri"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "accountability": {
      "type": "object",
      "properties": {
        "accountability_chain": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["role", "entity"],
            "properties": {
              "role": {
                "type": "string",
                "description": "Role in the accountability chain"
              },
              "entity": {
                "type": "string",
                "description": "Name of the accountable entity"
              },
              "contact": {
                "type": "string",
                "format": "uri"
              },
              "scope": {
                "type": "string",
                "description": "What this entity is accountable for"
              }
            },
            "additionalProperties": false
          }
        },
        "external_dependencies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["service", "provider"],
            "properties": {
              "service": {
                "type": "string"
              },
              "provider": {
                "type": "string"
              },
              "accountability_ref": {
                "type": "string",
                "format": "uri"
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "compliance_detail": {
      "type": "object",
      "properties": {
        "control_mappings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["framework", "control_id", "status"],
            "properties": {
              "framework": {
                "type": "string"
              },
              "control_id": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": ["implemented", "partial", "planned", "not_applicable"]
              },
              "evidence_uri": {
                "type": "string",
                "format": "uri"
              }
            },
            "additionalProperties": false
          }
        },
        "audit_schedule": {
          "type": "object",
          "properties": {
            "last_audit": {
              "type": "string",
              "format": "date-time"
            },
            "next_audit": {
              "type": "string",
              "format": "date-time"
            },
            "auditor": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
